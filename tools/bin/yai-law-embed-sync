#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
LAW_ROOT_DEFAULT="$(cd "$ROOT/.." && pwd)/law"
LAW_ROOT="${YAI_LAW_ROOT:-$LAW_ROOT_DEFAULT}"
TARGET_ROOT="${YAI_LAW_EMBED_ROOT:-$ROOT/embedded/law}"

if [[ ! -d "$LAW_ROOT" ]]; then
  echo "law root not found: $LAW_ROOT" >&2
  exit 2
fi

EXPORT_TOOL="$LAW_ROOT/tools/bin/law-export-embedded"
if [[ -x "$EXPORT_TOOL" ]]; then
  "$EXPORT_TOOL" "$TARGET_ROOT"
else
  echo "warning: law-export-embedded missing, using local fallback" >&2
  python3 - "$LAW_ROOT" "$TARGET_ROOT" <<'PY'
import json
import shutil
import sys
from pathlib import Path

law_root = Path(sys.argv[1]).resolve()
target = Path(sys.argv[2]).resolve()
manifest = json.loads((law_root / "manifests/embedded-export.manifest.json").read_text())

if target.exists():
    shutil.rmtree(target)
target.mkdir(parents=True, exist_ok=True)

for rel in ["VERSION", "manifests/law.manifest.json", "manifests/runtime.entrypoints.json"]:
    src = law_root / rel
    dst = target / ("law.manifest.json" if rel.endswith("law.manifest.json") else "runtime.entrypoints.json" if rel.endswith("runtime.entrypoints.json") else "VERSION")
    shutil.copy2(src, dst)

for rel in manifest.get("includes", []):
    src = law_root / rel
    if not src.exists():
        continue
    dst = target / rel
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)

for base in [
    "classification",
    "control-families",
    "domain-specializations",
    "overlays/regulatory",
    "overlays/sector",
    "overlays/contextual",
    "transitional/domain-family-seed",
]:
    src_root = law_root / base
    if not src_root.exists():
        continue
    for p in src_root.rglob("*.json"):
        out = target / p.relative_to(law_root)
        out.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(p, out)

for name in [
    "publish.index.json",
    "publish.layers.json",
    "compatibility.matrix.json",
    "domain-resolution-order.json",
    "compliance-resolution-order.json",
    "embedded-export.manifest.json",
]:
    src = law_root / "manifests" / name
    if src.exists():
        dst = target / "manifests" / name
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)

(target / "README.md").write_text(
    "# Embedded Law Surface\n\nGenerated runtime contract artifact from canonical law.\n",
    encoding="utf-8",
)
(target / "COMPATIBILITY.json").write_text(
    json.dumps(
        {
            "kind": "embedded-law-compatibility",
            "version": "v2",
            "law_version": (law_root / "VERSION").read_text().strip(),
            "compatibility_ref": "manifests/compatibility.matrix.json",
            "publish_layers_ref": "manifests/publish.layers.json",
        },
        indent=2,
    ) + "\n",
    encoding="utf-8",
)
print(f"embedded law synced: {target}")
PY
fi

echo "sync complete: $TARGET_ROOT"
