#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$ROOT/tools/dev/resolve-law-embed.sh"

EMBED_ROOT="$(yai_resolve_law_embed_root "$ROOT" || true)"
if [[ -z "$EMBED_ROOT" ]]; then
  echo "embedded law root not found (expected: $ROOT/embedded/law)" >&2
  exit 2
fi

python3 - "$ROOT" "$EMBED_ROOT" <<'PY'
import json
import sys
from pathlib import Path

root = Path(sys.argv[1])
embed = Path(sys.argv[2])

required = [
    "VERSION",
    "COMPATIBILITY.json",
    "law.manifest.json",
    "runtime.entrypoints.json",
    "domains/index/domains.index.json",
    "domains/index/domain-families.json",
    "domains/index/discovery-matrix.json",
    "domains/index/action-taxonomy.json",
    "domains/index/asset-taxonomy.json",
    "domains/index/risk-taxonomy.json",
    "compliance/index/compliance.index.json",
    "compliance/index/applicability.matrix.json",
    "compliance/index/domain-crosswalk.json",
    "compliance/index/authority-crosswalk.json",
    "manifests/publish.index.json",
    "manifests/compatibility.matrix.json",
    "manifests/domain-resolution-order.json",
    "manifests/compliance-resolution-order.json",
    "manifests/embedded-export.manifest.json",
    "generated/runtime-resolution-view.json",
    "generated/export.summary.json",
    "generated/compatibility.summary.json",
]

errors = []
for rel in required:
    p = embed / rel
    if not p.exists():
        errors.append(f"missing: {rel}")

for rel in [r for r in required if r.endswith('.json') and (embed / r).exists()]:
    try:
        json.loads((embed / rel).read_text())
    except Exception as exc:
        errors.append(f"invalid json: {rel} ({exc})")

# Ensure D1/D8 presence in embedded domains
for d in ["D1-digital", "D8-scientific"]:
    if not (embed / "domains" / d / "manifest.json").exists():
        errors.append(f"missing canonical embedded domain: {d}")

# Check top-level compatibility alignment
compat_file = root / "law-compatibility.v1.json"
if compat_file.exists() and (embed / "VERSION").exists():
    compat = json.loads(compat_file.read_text())
    embed_version = (embed / "VERSION").read_text().strip()
    if compat.get("embedded_law_version") and compat.get("embedded_law_version") != embed_version:
        errors.append(
            f"embedded version mismatch: law-compatibility.v1.json={compat.get('embedded_law_version')} embedded/VERSION={embed_version}"
        )

if errors:
    print("embedded law compatibility: FAIL")
    for e in errors:
        print(" -", e)
    raise SystemExit(1)

print("embedded law compatibility: OK")
print(f"embedded root: {embed}")
PY
