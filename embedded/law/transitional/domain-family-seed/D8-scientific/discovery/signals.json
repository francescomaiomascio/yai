{
  "kind": "discovery_profile",
  "version": "v1",
  "domain_id": "D8-scientific",
  "signals": [
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "experiment_run",
      "source": "runtime_event",
      "match_mode": "contains",
      "value": "run_experiment",
      "weight": 0.92,
      "notes": "Scientific pipeline execution request"
    },
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "parameter_lock",
      "source": "runtime_event",
      "match_mode": "contains",
      "value": "params_hash",
      "weight": 0.95,
      "notes": "Parameter lock / reproducibility indicator"
    },
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "black_box_mode",
      "source": "context",
      "match_mode": "contains",
      "value": "black-box",
      "weight": 0.75,
      "notes": "Lower transparency execution context requires tighter review"
    }
  ],
  "provider_matches": [
    "experiment-runner",
    "notebook-runtime",
    "pipeline-engine"
  ],
  "protocol_matches": [
    "file",
    "api",
    "control"
  ],
  "resource_matches": [
    "dataset",
    "model",
    "experiment-config",
    "result-artifact"
  ],
  "command_matches": [
    "experiment.run",
    "params.set",
    "params.lock",
    "result.publish"
  ],
  "fallback_rules": [
    "missing-params-lock:deny",
    "ambiguous-provenance:quarantine"
  ]
}
