{
  "kind": "discovery_profile",
  "version": "v1",
  "domain_id": "D1-digital",
  "signals": [
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "network_egress",
      "source": "runtime_event",
      "match_mode": "contains",
      "value": "curl",
      "weight": 0.95,
      "notes": "Covers RT-0.1-001 curl egress trial"
    },
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "telemetry_export",
      "source": "runtime_event",
      "match_mode": "contains",
      "value": "otel",
      "weight": 0.9,
      "notes": "Covers RT-0.1-002 OTEL exporter egress trial"
    },
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "object_storage_upload",
      "source": "runtime_event",
      "match_mode": "contains",
      "value": "s3",
      "weight": 0.9,
      "notes": "Covers RT-0.1-003 S3 upload egress trial"
    },
    {
      "kind": "discovery_signal",
      "version": "v1",
      "signal_type": "external_publication",
      "source": "command",
      "match_mode": "contains",
      "value": "github issue comment",
      "weight": 0.82,
      "notes": "Covers RT-0.1-004 external issue comment publication"
    }
  ],
  "provider_matches": [
    "curl",
    "otel-exporter",
    "aws-s3",
    "github-api"
  ],
  "protocol_matches": [
    "http",
    "https",
    "grpc"
  ],
  "resource_matches": [
    "remote-endpoint",
    "external-repository",
    "object-storage-bucket"
  ],
  "command_matches": [
    "egress.connect",
    "otel.export",
    "s3.put_object",
    "github.issues.comment.create"
  ],
  "fallback_rules": [
    "when-signals-low-confidence:review_required",
    "when-authority-missing:quarantine"
  ]
}
