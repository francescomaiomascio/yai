{
  "kind": "domain_policy_pack",
  "version": "v1",
  "pack_id": "D1-digital.deny",
  "domain_id": "D1-digital",
  "pack_type": "deny",
  "rules": [
    {
      "rule_id": "D1-digital.deny.uncontracted-egress",
      "status": "active",
      "scope": {
        "actions": [
          "egress",
          "publish"
        ]
      },
      "conditions": [
        {
          "resource": "external_endpoint"
        },
        {
          "authority": "missing_contract"
        }
      ],
      "effect": "deny",
      "priority": 1000,
      "evidence_requirements": [
        "decision_record",
        "resolution_trace"
      ]
    },
    {
      "rule_id": "D1-digital.deny.credential-leak-pattern",
      "status": "active",
      "scope": {
        "assets": [
          "credential"
        ]
      },
      "conditions": [
        {
          "context_flag": "sensitive_payload"
        }
      ],
      "effect": "deny",
      "priority": 1100,
      "evidence_requirements": [
        "decision_record",
        "resolution_trace"
      ]
    }
  ],
  "default_effect": "deny"
}
