{
  "kind": "domain_policy_pack",
  "version": "v1",
  "pack_id": "D8-scientific.deny",
  "domain_id": "D8-scientific",
  "pack_type": "deny",
  "rules": [
    {
      "rule_id": "D8-scientific.deny.unauthorized-param-mutation",
      "status": "active",
      "scope": {
        "actions": [
          "parameter-modify"
        ]
      },
      "conditions": [
        {
          "authority": "missing_controller_approval"
        }
      ],
      "effect": "deny",
      "priority": 1100
    },
    {
      "rule_id": "D8-scientific.deny.missing-provenance",
      "status": "active",
      "scope": {
        "assets": [
          "dataset",
          "model",
          "output"
        ]
      },
      "conditions": [
        {
          "context_flag": "provenance_missing"
        }
      ],
      "effect": "deny",
      "priority": 1080
    }
  ],
  "default_effect": "deny"
}
